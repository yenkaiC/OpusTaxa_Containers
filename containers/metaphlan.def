Bootstrap: docker
From: condaforge/miniforge3:latest

%labels
    Author OpusTaxa
    Tool metaphlan
    Version 4.2.4

%post
    apt-get update && apt-get install -y procps && apt-get clean -y
    mamba install -y -c conda-forge -c bioconda \
        metaphlan=4.2.4
    mamba clean -a -y

%environment
    export PATH=/opt/conda/bin:$PATH

%runscript
    exec "$@"
