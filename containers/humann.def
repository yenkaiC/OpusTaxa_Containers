Bootstrap: docker
From: condaforge/miniforge3:latest

%labels
    Author OpusTaxa
    Tool humann
    Version 3.9

%post
    apt-get update && apt-get install -y procps && apt-get clean -y
    mamba install -y -c conda-forge -c bioconda \
        python=3.9 \
        diamond \
        glpk \
        pip
    pip install humann==3.9
    mamba clean -a -y
    pip cache purge

%environment
    export PATH=/opt/conda/bin:$PATH

%runscript
    exec "$@"
